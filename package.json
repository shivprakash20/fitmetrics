{
  "name": "fitmetrics-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @fitmetrics/web",
    "dev:web": "npm run dev --workspace @fitmetrics/web",
    "dev:mobile": "npm run start --workspace @fitmetrics/mobile",
    "build": "npm run build --workspace @fitmetrics/web",
    "start": "npm run start --workspace @fitmetrics/web",
    "lint": "npm run lint --workspace @fitmetrics/web",
    "typecheck": "npm run typecheck --workspace @fitmetrics/web",
    "lint:all": "npm run lint --workspaces --if-present"
  }
}
