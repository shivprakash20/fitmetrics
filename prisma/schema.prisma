generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum OtpPurpose {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model User {
  id              String               @id @default(cuid())
  email           String               @unique
  passwordHash    String
  firstName       String
  middleName      String?
  lastName        String
  gender          Gender
  mobile          String               @unique
  emailVerifiedAt DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  otpCodes        OtpCode[]
  sessions        Session[]
  readings        CalculatorReading[]
}

model CalculatorReading {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calculatorType String
  inputs         Json
  result         Json
  savedAt        DateTime @default(now())

  @@index([userId, calculatorType, savedAt])
}

model OtpCode {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose    OtpPurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([userId, purpose, expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model ContactSubmission {
  email     String   @id
  name      String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
